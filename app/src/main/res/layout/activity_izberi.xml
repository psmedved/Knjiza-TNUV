<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ozadje"
    tools:context=".MainActivity">

    <!--Zgornja navigacijska vrstica: ime strani-->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/top_app_bar_menu"
        android:layout_width="0dp"
        android:layout_height="?attr/actionBarSize"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">
    </androidx.appcompat.widget.Toolbar>

    <!--Vsebina aplikacije-->
    <LinearLayout
        android:id="@+id/vsebina_aplikacije"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        app:layout_constraintTop_toBottomOf="@id/top_app_bar_menu"
        app:layout_constraintBottom_toTopOf="@id/bottom_app_bar_menu"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!--Zgornje okno vsebine-->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center">
            <EditText
                android:id="@+id/polje_besedilo_izberi"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="" />
        </LinearLayout>

        <!--Spodnje okno vsebine-->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <EditText
                    android:id="@+id/polje_komentar_izberi"
                    android:layout_width="match_parent"
                    android:layout_height="45dp"
                    android:hint="@string/zacasni_napis_komentar"
                    android:inputType="text"
                    android:layout_weight="1" />
            </LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btn_i_ponovi"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_margin="10dp"
                    android:layout_weight="1"
                    android:text="@string/navigacija_ponovi" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!--Spodnja navigacijska vrstica: nazaj, domov, potrdi-->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_app_bar_menu"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:menu="@menu/bottom_navigacija"
        app:layout_constraintTop_toBottomOf="@id/vsebina_aplikacije"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>

